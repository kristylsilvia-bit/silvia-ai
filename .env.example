# Copy this file to ".env" and drop in your Google Gemini API key.
# Get a key at https://aistudio.google.com/apikey
#
# NOTE: Vite inlines VITE_* variables into the client bundle at build time.
# This is fine for local/personal use, but for a public deployment you should
# proxy Gemini calls through a small backend so the key is never shipped to
# the browser. See README.md → "Production hardening".
VITE_GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# Firebase — get these from Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
