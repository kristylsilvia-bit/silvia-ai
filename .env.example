# ── Gemini (client) ─────────────────────────────────────────────
# Used for chat/image calls and as the local-dev Voice Mode fallback.
# Get a key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# ── Firebase web config (Auth + Firestore chat sync) ────────────
# From Firebase console → Project settings → Your apps → Web app.
# Leave blank to run in guest mode (local-only chats, no sign-in).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Gemini (server only — set in Vercel, NOT exposed to client) ─
# Used by api/live-token.ts to mint ephemeral Voice Mode tokens.
GEMINI_API_KEY=
